# =============================================================================
# AI Expense Intelligence Platform - Environment Variables
# =============================================================================
# Copy this file to .env and fill in the values for your environment.

# --- Database ---
DATABASE_URL=postgresql://expense_user:expense_pass@localhost:5432/expense_db

# --- Redis ---
REDIS_URL=redis://localhost:6379/0

# --- OpenAI / LLM ---
OPENAI_API_KEY=sk-your-openai-api-key-here
OPENAI_MODEL=gpt-4o

# --- Authentication ---
JWT_SECRET=change-me-to-a-random-secret
# Shared secret for service-to-service calls; required in production
INTERNAL_API_TOKEN=change-me-to-a-random-secret
JWT_ALGORITHM=HS256
JWT_EXPIRATION_MINUTES=30

# --- Object Storage (S3 / MinIO) ---
S3_BUCKET=expense-documents
S3_ENDPOINT=http://localhost:9000
S3_ACCESS_KEY=minioadmin
S3_SECRET_KEY=minioadmin
S3_REGION=us-east-1

# --- Celery / Task Queue ---
CELERY_BROKER_URL=redis://localhost:6379/1
CELERY_RESULT_BACKEND=redis://localhost:6379/2

# --- Notifications ---
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASSWORD=
SLACK_WEBHOOK_URL=

# --- Service URLs (for inter-service communication) ---
API_GATEWAY_URL=http://localhost:8000
AI_ENGINE_URL=http://localhost:8001
EXPENSE_PROCESSOR_URL=http://localhost:8002
POLICY_ENGINE_URL=http://localhost:8003

# --- Logging ---
LOG_LEVEL=INFO

# --- Environment ---
ENVIRONMENT=development
